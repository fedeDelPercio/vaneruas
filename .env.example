# ==========================================================================
# atp-template — variables de entorno
# Copiar este archivo como .env.local y completar los valores.
# ==========================================================================

# --- Supabase -------------------------------------------------------------
# Project Settings > API en el dashboard de Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# JWT firmado con el JWT secret del proyecto, con claim `client_slug`. Se
# envía como Authorization: Bearer para que PostgREST lo lea via auth.jwt()
# en las policies de RLS. NO reemplaza al anon key (sigue siendo el "apikey").
# Generar con scripts/gen-client-jwt.mjs (si se incluye) o un firmador HS256.
NEXT_PUBLIC_SUPABASE_CLIENT_JWT=
# Service role: NUNCA exponer al cliente. Solo se usa en API routes / worker.
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic ------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_ORCHESTRATOR=claude-sonnet-4-6
ANTHROPIC_MODEL_SUBAGENT=claude-haiku-4-5
ANTHROPIC_MODEL_EVALUATOR=claude-haiku-4-5

# --- Configuración del agente ---------------------------------------------
AGENT_MAX_ITERATIONS=3
AGENT_TIMEOUT_MS=60000

# --- Webhooks / jobs ------------------------------------------------------
# CRON_SECRET protege el endpoint /api/jobs/process (header x-cron-secret).
CRON_SECRET=
# WEBHOOK_SIGNING_SECRET firma (HMAC) los webhooks salientes.
WEBHOOK_SIGNING_SECRET=
# GHL_WEBHOOK_SECRET (opcional): segunda capa de auth para el webhook entrante
# de GoHighLevel (/api/webhooks/ghl/inbound, header x-ghl-secret). Si se deja
# vacío, el endpoint no exige el header.
GHL_WEBHOOK_SECRET=
# GHL_API_KEY: Private Integration Token (scope conversations/message.write)
# para que el agente responda por WhatsApp vía GHL. Si falta, el envío saliente
# queda deshabilitado (la respuesta igual queda en el panel).
GHL_API_KEY=
# GHL_SEND_ALLOWLIST: guardrail fail-closed de a quién PUEDE responder el agente
# por WhatsApp. Vacío -> nadie. "*" -> todos (producción). "id1,id2" -> solo esos
# contact_id de GHL. Ej. de testing: un solo contacto.
GHL_SEND_ALLOWLIST=
# GHL_PAUSE_TAG: tag de GHL que pausa la IA (la atiende un humano). Default
# "ia-pausada". Un workflow "Contact Tag" (add/remove) pega a /api/webhooks/ghl/mode.
GHL_PAUSE_TAG=ia-pausada
# OPENAI_API_KEY: transcripción de notas de voz de WhatsApp (Whisper). Si falta,
# los audios quedan como placeholder y el agente pide que los escriban (no rompe).
OPENAI_API_KEY=
# Modelo de transcripción. Default gpt-4o-transcribe; se puede bajar a whisper-1.
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
# MESSAGE_DEBOUNCE_SECONDS: acumulación de mensajes en WhatsApp. Ventana de
# silencio (segundos) antes de consolidar y responder los mensajes seguidos.
# Testing: 20. Producción: ~60. 0 = desactivado (responde cada mensaje al toque).
MESSAGE_DEBOUNCE_SECONDS=20
# --- App de GHL (webhooks InboundMessage/OutboundMessage + OAuth) -----------
# Credenciales de la Private App (developer marketplace). Por ahora opcionales:
# para RECIBIR webhooks no hace falta el token OAuth (enviamos con el PIT). Se
# usan si en el futuro intercambiamos el code por token (ej. bajar adjuntos).
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
# Clave pública de GHL para verificar la firma de los webhooks de la app
# (x-ghl-signature Ed25519). Opcional: si está, se verifica; si no, se confía
# en el bypass de Deployment Protection (que va en la URL como query param).
GHL_WEBHOOK_PUBLIC_KEY=

# --- Cliente activo (multi-tenant) ----------------------------------------
# Slug del cliente que opera este worktree/deploy. El aislamiento real de
# datos lo hace RLS via el claim `client_slug` del CLIENT_JWT (ver
# supabase/migrations/004). Convención: snake_case.
NEXT_PUBLIC_CLIENT_SLUG=
# NEXT_PUBLIC_GHL_LOCATION_ID (opcional): locationId de la subcuenta de GHL.
# Lo usa el panel para armar el link directo a la conversación en GHL ("Ver
# conversación" en Aprobaciones, Derivaciones y Certificados). Si falta, esos
# botones caen al visor interno del panel.
NEXT_PUBLIC_GHL_LOCATION_ID=

# --- App ------------------------------------------------------------------
# URL base de la app (usada por el auto-trigger del worker y por los deep
# links en emails). En producción: la URL del deploy. En local: tu localhost.
NEXT_PUBLIC_APP_URL=http://localhost:3102

# --- Email (notificaciones al equipo) — OPCIONAL --------------------------
# Si las tres están seteadas, el agente manda un email a EMAIL_NOTIFY_TO
# cada vez que se registra una notificación NUEVA en agent_notifications
# (cualquier categoría: interés, fuera de KB, falla técnica, etc.).
# Si alguna falta, el sender hace skip silencioso y la app sigue.
# La cuenta GMAIL_USER tiene que tener 2FA + App Password generada en
# https://myaccount.google.com/apppasswords.
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_NOTIFY_TO=
